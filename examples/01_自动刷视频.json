{
  "id": "auto_scroll_social_feed",
  "name": "全自动沉浸式刷视频",
  "description": "打开抖音并自动无限上滑浏览，带随机停留时间，解放双手。",
  "launchApp": {
    "type": "launchApp",
    "packageName": "com.ss.android.ugc.aweme",
    "appName": "抖音"
  },
  "goals": [
    {
      "id": "swipe_up_loop",
      "name": "无限上滑浏览视频",
      "trigger": { "type": "immediate" },
      "action": {
        "type": "swipe",
        "startXPct": 0.5,
        "startYPct": 0.8,
        "endXPct": 0.5,
        "endYPct": 0.2,
        "durationMs": 300,
        "note": "向上滑动切换下一个视频"
      },
      "constraints": {
        "maxExecutions": 0,
        "cooldownMs": 8000,
        "executionMode": "REPEAT"
      }
    }
  ]
}
