{
  "id": "tiktok_smart_browser_v2",
  "name": "抖音智能化刷视频与互动",
  "description": "V2新特性演示：全局弹窗拦截、语义识别、向外求助、相对滑动",
  "launchApp": {
    "type": "launchApp",
    "packageName": "com.ss.android.ugc.aweme",
    "appName": "抖音"
  },
  "interrupts": [
    {
      "name": "青少年模式弹窗",
      "when": {
        "type": "semantic",
        "description": "青少年模式弹窗提醒"
      },
      "dismiss": {
        "type": "semantic",
        "description": "我知道了按钮或关闭弹窗的叉号"
      },
      "priority": 10
    },
    {
      "name": "版本更新提示",
      "when": {
        "type": "semantic",
        "description": "发现新版本或立即升级提示框"
      },
      "dismiss": {
        "type": "semantic",
        "description": "以后再说或暂不更新按钮"
      },
      "priority": 9
    }
  ],
  "goals": [
    {
      "id": "swipe_video",
      "name": "上滑看下一个视频",
      "trigger": {
        "type": "immediate"
      },
      "action": {
        "type": "swipe",
        "startXPct": 0.5,
        "startYPct": 0.8,
        "endXPct": 0.5,
        "endYPct": 0.2,
        "delayMs": 3000
      }
    },
    {
      "id": "open_comments",
      "name": "打开评论区",
      "trigger": {
        "type": "afterGoal",
        "goalId": "swipe_video"
      },
      "action": {
        "type": "tap",
        "target": {
          "type": "semantic",
          "description": "视频右侧的评论图标按钮"
        },
        "delayMs": 1000
      }
    },
    {
      "id": "relative_swipe_comments",
      "name": "在评论列表内滑动",
      "trigger": {
        "type": "afterGoal",
        "goalId": "open_comments"
      },
      "action": {
        "type": "swipe",
        "startXPct": 0.5,
        "startYPct": 0.8,
        "endXPct": 0.5,
        "endYPct": 0.2,
        "target": {
          "type": "semantic",
          "description": "评论区列表面板控件"
        },
        "delayMs": 1000
      }
    },
    {
      "id": "like_first_comment",
      "name": "给某条评论点赞",
      "trigger": {
        "type": "afterGoal",
        "goalId": "relative_swipe_comments"
      },
      "action": {
        "type": "tap",
        "target": {
          "type": "semantic",
          "description": "红色的爱心点赞图标"
        }
      }
    }
  ],
  "termination": {
    "type": "allGoalsDone"
  }
}
