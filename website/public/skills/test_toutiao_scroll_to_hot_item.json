{
  "id": "reactive_test_toutiao_scroll_to_hot_item",
  "name": "今日头条热榜滚动定位测试",
  "description": "打开头条后进入热榜页，滚动查找并点击热榜条目“郑丽文访陆”。",
  "agentId": "agent_life",
  "goals": [
    {
      "id": "launch_toutiao",
      "name": "启动头条",
      "priority": 10,
      "trigger": { "type": "immediate" },
      "actions": [
        {
          "type": "launchApp",
          "packageName": "com.ss.android.article.news",
          "appName": "今日头条",
          "delayMs": 500,
          "timeoutMs": 8000
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "click_hot",
      "name": "点击热榜",
      "priority": 8,
      "trigger": {
        "type": "allOf",
        "triggers": [
          { "type": "afterGoal", "goalId": "launch_toutiao" },
          { "type": "elementVisible", "target": { "type": "desc", "desc": "热榜" } }
        ]
      },
      "actions": [
        {
          "type": "tap",
          "target": { "type": "desc", "desc": "热榜" },
          "delayMs": 300,
          "timeoutMs": 2000
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "scroll_target",
      "name": "滚动定位热榜条目",
      "priority": 6,
      "trigger": {
        "type": "afterGoal",
        "goalId": "click_hot"
      },
      "actions": [
        {
          "type": "delay",
          "durationMs": 1200
        },
        {
          "type": "scrollTo",
          "target": { "type": "desc", "desc": "郑丽文访陆" },
          "direction": "DOWN",
          "maxScrolls": 6,
          "scrollDurationMs": 420,
          "settleDelayMs": 700,
          "tapWhenFound": true,
          "delayMs": 200,
          "timeoutMs": 2500
        },
        {
          "type": "notify",
          "message": "已滚动定位并点击热榜条目：郑丽文访陆",
          "showText": true,
          "speakVoice": false,
          "delayMs": 300
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    }
  ],
  "termination": { "type": "allGoalsDone" },
  "pacingPreset": "STANDARD",
  "scanConfig": {
    "idleIntervalMs": 700,
    "activeIntervalMs": 300,
    "fallbackToImageMatch": false
  },
  "returnToApp": false
}
