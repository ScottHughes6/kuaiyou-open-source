{
  "id": "reactive_test_toutiao_swipe_hotlist",
  "name": "今日头条热榜上滑测试",
  "description": "打开头条后进入热榜页并执行上滑，验证热榜场景下的 Swipe。",
  "agentId": "agent_life",
  "goals": [
    {
      "id": "launch_toutiao",
      "name": "启动头条",
      "priority": 10,
      "trigger": { "type": "immediate" },
      "actions": [
        {
          "type": "launchApp",
          "packageName": "com.ss.android.article.news",
          "appName": "今日头条",
          "delayMs": 500,
          "timeoutMs": 8000
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "click_hot",
      "name": "点击热榜",
      "priority": 8,
      "trigger": {
        "type": "allOf",
        "triggers": [
          { "type": "afterGoal", "goalId": "launch_toutiao" },
          { "type": "elementVisible", "target": { "type": "desc", "desc": "热榜" } }
        ]
      },
      "actions": [
        {
          "type": "tap",
          "target": { "type": "desc", "desc": "热榜" },
          "delayMs": 300,
          "timeoutMs": 2000
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "swipe_hotlist",
      "name": "热榜页上滑",
      "priority": 6,
      "trigger": {
        "type": "afterGoal",
        "goalId": "click_hot"
      },
      "actions": [
        {
          "type": "delay",
          "durationMs": 1200
        },
        {
          "type": "swipe",
          "startXPct": 0.5,
          "startYPct": 0.82,
          "endXPct": 0.5,
          "endYPct": 0.34,
          "durationMs": 420,
          "delayMs": 200
        },
        {
          "type": "notify",
          "message": "热榜页上滑完成，请检查条目是否发生变化",
          "speakVoice": false,
          "showText": true,
          "delayMs": 300
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    }
  ],
  "termination": { "type": "allGoalsDone" },
  "pacingPreset": "STANDARD",
  "scanConfig": {
    "idleIntervalMs": 700,
    "activeIntervalMs": 300,
    "fallbackToImageMatch": false
  },
  "returnToApp": false
}
