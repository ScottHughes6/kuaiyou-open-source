{
  "id": "reactive_test_element_wait",
  "name": "反复等待元素测试",
  "description": "测试 elementVisible 触发 + 冷却 + 多次执行：持续监听屏幕上某个按钮，每次出现就点击，最多 3 次",
  "goals": [
    {
      "id": "click_confirm",
      "name": "点击确认按钮",
      "priority": 5,
      "trigger": {
        "type": "elementVisible",
        "target": { "type": "text", "text": "确认" }
      },
      "actions": [
        {
          "type": "tap",
          "target": { "type": "text", "text": "确认" },
          "timeoutMs": 2000,
          "delayMs": 200
        },
        {
          "type": "notify",
          "message": "已点击确认按钮",
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 3,
        "cooldownMs": 2000,
        "continueOnFailure": true,
        "enabled": true
      }
    }
  ],
  "termination": { "type": "timeout", "maxDurationMs": 30000 },
  "pacingPreset": "FAST",
  "scanConfig": {
    "idleIntervalMs": 300,
    "activeIntervalMs": 150,
    "fallbackToImageMatch": false
  }
}
