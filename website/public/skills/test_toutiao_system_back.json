{
  "id": "reactive_test_toutiao_system_back",
  "name": "今日头条返回键测试",
  "description": "打开头条搜索页后执行 BACK，验证能回到首页并再次看到听一听开关。",
  "agentId": "agent_life",
  "goals": [
    {
      "id": "launch_toutiao",
      "name": "启动头条",
      "priority": 10,
      "trigger": { "type": "immediate" },
      "actions": [
        {
          "type": "launchApp",
          "packageName": "com.ss.android.article.news",
          "appName": "今日头条",
          "delayMs": 500,
          "timeoutMs": 8000
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "normalize_home",
      "name": "确认回到首页",
      "priority": 9,
      "trigger": {
        "type": "afterGoal",
        "goalId": "launch_toutiao"
      },
      "actions": [
        {
          "type": "conditionBranch",
          "condition": {
            "type": "elementVisible",
            "target": { "type": "desc", "desc": "听一听开关" }
          },
          "onTrue": [
            { "type": "delay", "durationMs": 400 }
          ],
          "onFalse": [
            { "type": "systemAction", "systemType": "BACK", "delayMs": 300 },
            { "type": "delay", "durationMs": 1200 }
          ],
          "timeoutMs": 1200
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "open_search",
      "name": "点击首页搜索入口",
      "priority": 8,
      "trigger": {
        "type": "allOf",
        "triggers": [
          { "type": "afterGoal", "goalId": "normalize_home" },
          { "type": "elementVisible", "target": { "type": "id", "viewId": "com.ss.android.article.news:id/ki9" } }
        ]
      },
      "actions": [
        {
          "type": "tap",
          "target": { "type": "id", "viewId": "com.ss.android.article.news:id/ki9" },
          "delayMs": 300
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "verify_search_page",
      "name": "确认进入搜索页",
      "priority": 7,
      "trigger": {
        "type": "allOf",
        "triggers": [
          { "type": "afterGoal", "goalId": "open_search" },
          { "type": "elementVisible", "target": { "type": "id", "viewId": "com.ss.android.article.news:id/e0" } }
        ]
      },
      "actions": [
        {
          "type": "notify",
          "message": "已进入搜索页",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "back_home",
      "name": "执行返回并处理搜索页中间态",
      "priority": 6,
      "trigger": {
        "type": "allOf",
        "triggers": [
          { "type": "afterGoal", "goalId": "verify_search_page" },
          { "type": "elementVisible", "target": { "type": "id", "viewId": "com.ss.android.article.news:id/e0" } }
        ]
      },
      "actions": [
        {
          "type": "systemAction",
          "systemType": "BACK",
          "delayMs": 300
        },
        {
          "type": "delay",
          "durationMs": 900
        },
        {
          "type": "conditionBranch",
          "condition": {
            "type": "elementVisible",
            "target": { "type": "id", "viewId": "com.ss.android.article.news:id/e0" }
          },
          "onTrue": [
            { "type": "systemAction", "systemType": "BACK", "delayMs": 300 },
            { "type": "delay", "durationMs": 1200 }
          ],
          "onFalse": [
            { "type": "delay", "durationMs": 400 }
          ],
          "timeoutMs": 1200
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "verify_home",
      "name": "验证返回首页",
      "priority": 4,
      "trigger": {
        "type": "allOf",
        "triggers": [
          { "type": "afterGoal", "goalId": "back_home" },
          { "type": "elementVisible", "target": { "type": "desc", "desc": "听一听开关" } }
        ]
      },
      "actions": [
        {
          "type": "notify",
          "message": "返回首页成功，已看到听一听开关",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    }
  ],
  "termination": { "type": "allGoalsDone" },
  "pacingPreset": "STANDARD",
  "scanConfig": {
    "idleIntervalMs": 600,
    "activeIntervalMs": 250,
    "fallbackToImageMatch": false
  },
  "returnToApp": false
}
