{
  "id": "reactive_test_toutiao_clipboard_delay",
  "name": "今日头条剪贴板与延时测试",
  "description": "验证 SetClipboard、Delay、Notify 这类不依赖复杂页面反馈的动作。",
  "agentId": "agent_life",
  "goals": [
    {
      "id": "launch_toutiao",
      "name": "启动头条",
      "priority": 10,
      "trigger": { "type": "immediate" },
      "actions": [
        {
          "type": "launchApp",
          "packageName": "com.ss.android.article.news",
          "appName": "今日头条",
          "delayMs": 500,
          "timeoutMs": 8000
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "clipboard_and_delay",
      "name": "设置剪贴板并等待",
      "priority": 6,
      "trigger": {
        "type": "afterGoal",
        "goalId": "launch_toutiao"
      },
      "actions": [
        {
          "type": "setClipboard",
          "text": "头条剪贴板测试"
        },
        {
          "type": "delay",
          "durationMs": 1200
        },
        {
          "type": "notify",
          "message": "剪贴板和延时动作完成",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    }
  ],
  "termination": { "type": "allGoalsDone" },
  "pacingPreset": "STANDARD",
  "scanConfig": {
    "idleIntervalMs": 600,
    "activeIntervalMs": 250,
    "fallbackToImageMatch": false
  },
  "returnToApp": false
}
