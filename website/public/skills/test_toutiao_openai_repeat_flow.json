{
  "id": "reactive_test_toutiao_openai_repeat_flow",
  "name": "今日头条搜索 OpenAI官宣 + REPEAT 重读测试",
  "description": "搜索 OpenAI，滚动查找含官宣的文章并进入详情，读取标题后自动按 HOME 离开再重启头条，验证 REPEAT goal 在 appInForeground false→true 过渡时重新触发并再次读取内容。",
  "agentId": "agent_life",
  "goals": [
    {
      "id": "launch_toutiao",
      "name": "①启动今日头条",
      "priority": 16,
      "trigger": {
        "type": "immediate"
      },
      "actions": [
        {
          "type": "launchApp",
          "packageName": "com.ss.android.article.news",
          "appName": "今日头条",
          "delayMs": 500,
          "timeoutMs": 8000
        },
        {
          "type": "notify",
          "message": "①启动今日头条",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "normalize_home",
      "name": "②确认回到首页",
      "priority": 14,
      "trigger": {
        "type": "afterGoal",
        "goalId": "launch_toutiao"
      },
      "actions": [
        {
          "type": "conditionBranch",
          "condition": {
            "type": "elementVisible",
            "target": {
              "type": "desc",
              "desc": "听一听开关"
            }
          },
          "onTrue": [
            {
              "type": "delay",
              "durationMs": 400
            }
          ],
          "onFalse": [
            {
              "type": "systemAction",
              "systemType": "BACK",
              "delayMs": 300
            },
            {
              "type": "delay",
              "durationMs": 1200
            }
          ],
          "timeoutMs": 1200
        },
        {
          "type": "notify",
          "message": "②已确认首页",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "open_search",
      "name": "③点击首页搜索入口",
      "priority": 12,
      "trigger": {
        "type": "allOf",
        "triggers": [
          {
            "type": "afterGoal",
            "goalId": "normalize_home"
          },
          {
            "type": "elementVisible",
            "target": {
              "type": "id",
              "viewId": "com.ss.android.article.news:id/ki9"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "tap",
          "target": {
            "type": "id",
            "viewId": "com.ss.android.article.news:id/ki9"
          },
          "delayMs": 300,
          "timeoutMs": 2000
        },
        {
          "type": "notify",
          "message": "③已点击搜索入口",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "type_openai",
      "name": "④输入 OpenAI",
      "priority": 10,
      "trigger": {
        "type": "allOf",
        "triggers": [
          {
            "type": "afterGoal",
            "goalId": "open_search"
          },
          {
            "type": "elementVisible",
            "target": {
              "type": "id",
              "viewId": "com.ss.android.article.news:id/cx"
            }
          },
          {
            "type": "elementVisible",
            "target": {
              "type": "id",
              "viewId": "com.ss.android.article.news:id/e0"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "typeText",
          "text": "OpenAI",
          "target": {
            "type": "id",
            "viewId": "com.ss.android.article.news:id/cx"
          },
          "clearFirst": true,
          "mode": "DEFAULT",
          "delayMs": 300,
          "timeoutMs": 2500
        },
        {
          "type": "notify",
          "message": "④已输入 OpenAI",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "submit_search",
      "name": "⑤点击搜索按钮",
      "priority": 9,
      "trigger": {
        "type": "allOf",
        "triggers": [
          {
            "type": "afterGoal",
            "goalId": "type_openai"
          },
          {
            "type": "elementVisible",
            "target": {
              "type": "id",
              "viewId": "com.ss.android.article.news:id/e0"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "tap",
          "target": {
            "type": "id",
            "viewId": "com.ss.android.article.news:id/e0"
          },
          "delayMs": 300,
          "timeoutMs": 2500
        },
        {
          "type": "notify",
          "message": "⑤已提交搜索，等待结果页…",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "wait_results",
      "name": "⑥等待搜索结果页",
      "priority": 8,
      "trigger": {
        "type": "afterGoal",
        "goalId": "submit_search"
      },
      "actions": [
        {
          "type": "waitFor",
          "condition": {
            "type": "elementVisible",
            "target": {
              "type": "text",
              "text": "OpenAI",
              "exact": false
            }
          },
          "timeoutMs": 8000
        },
        {
          "type": "notify",
          "message": "⑥搜索结果页已就绪，开始滚动查找官宣文章…",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "scroll_find_article",
      "name": "⑦滚动查找并点击含官宣的文章",
      "priority": 7,
      "trigger": {
        "type": "afterGoal",
        "goalId": "wait_results"
      },
      "actions": [
        {
          "type": "notify",
          "message": "⑦开始滚动查找官宣主题…",
          "showText": true,
          "speakVoice": false
        },
        {
          "type": "scrollTo",
          "target": {
            "type": "composite",
            "text": "官宣",
            "textExact": false,
            "index": 0
          },
          "direction": "UP",
          "scrollPath": {
            "startXPct": 0.5,
            "startYPct": 0.76,
            "endXPct": 0.5,
            "endYPct": 0.42,
            "durationMs": 520
          },
          "maxScrolls": 8,
          "scrollDurationMs": 450,
          "settleDelayMs": 800,
          "scrollRegion": {
            "leftPct": 0.08,
            "topPct": 0.3,
            "rightPct": 0.92,
            "bottomPct": 0.88
          },
          "tapWhenFound": true,
          "delayMs": 800,
          "timeoutMs": 12000
        },
        {
          "type": "notify",
          "message": "⑧已滚动定位并点击官宣文章",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "wait_article_detail",
      "name": "⑧等待文章详情页",
      "priority": 6,
      "trigger": {
        "type": "afterGoal",
        "goalId": "scroll_find_article"
      },
      "actions": [
        {
          "type": "waitFor",
          "condition": {
            "type": "anyOf",
            "conditions": [
              {
                "type": "elementVisible",
                "target": {
                  "type": "text",
                  "text": "分享",
                  "exact": false
                }
              },
              {
                "type": "elementVisible",
                "target": {
                  "type": "text",
                  "text": "评论",
                  "exact": false
                }
              },
              {
                "type": "elementVisible",
                "target": {
                  "type": "text",
                  "text": "收藏",
                  "exact": false
                }
              }
            ]
          },
          "timeoutMs": 12000
        },
        {
          "type": "notify",
          "message": "⑨已进入文章详情页",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "read_title_once",
      "name": "⑨首次读取文章标题",
      "priority": 5,
      "trigger": {
        "type": "allOf",
        "triggers": [
          {
            "type": "afterGoal",
            "goalId": "wait_article_detail"
          },
          {
            "type": "elementVisible",
            "target": {
              "type": "text",
              "text": "OpenAI",
              "exact": false
            }
          }
        ]
      },
      "actions": [
        {
          "type": "readText",
          "target": {
            "type": "text",
            "text": "OpenAI",
            "exact": false
          },
          "variableName": "article_title",
          "delayMs": 300,
          "timeoutMs": 3000
        },
        {
          "type": "notify",
          "message": "⑩首次读取：{{article_title}}",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": true,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "press_home_to_leave",
      "name": "⑩按 HOME 离开头条（为 REPEAT 创造 false→true 条件）",
      "priority": 4,
      "trigger": {
        "type": "afterGoal",
        "goalId": "read_title_once"
      },
      "actions": [
        {
          "type": "notify",
          "message": "REPEAT 测试准备：即将按 HOME 键离开头条",
          "showText": true,
          "speakVoice": false
        },
        {
          "type": "systemAction",
          "systemType": "HOME",
          "delayMs": 500
        },
        {
          "type": "delay",
          "durationMs": 2000
        },
        {
          "type": "notify",
          "message": "已离开头条，2 秒后重新启动触发 REPEAT…",
          "showText": true,
          "speakVoice": false
        },
        {
          "type": "delay",
          "durationMs": 2000
        },
        {
          "type": "launchApp",
          "packageName": "com.ss.android.article.news",
          "appName": "今日头条",
          "delayMs": 500,
          "timeoutMs": 6000
        },
        {
          "type": "notify",
          "message": "已重新进入头条，等待 REPEAT goal 触发",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "repeat_reread_on_foreground",
      "name": "REPEAT：切回文章详情时重新读取",
      "priority": 2,
      "trigger": {
        "type": "allOf",
        "triggers": [
          {
            "type": "afterGoal",
            "goalId": "press_home_to_leave"
          },
          {
            "type": "appInForeground",
            "packageName": "com.ss.android.article.news"
          }
        ]
      },
      "actions": [
        {
          "type": "notify",
          "message": "🔁 REPEAT 触发：头条重新进入前台",
          "showText": true,
          "speakVoice": false
        },
        {
          "type": "delay",
          "durationMs": 500
        },
        {
          "type": "notify",
          "message": "🔁 REPEAT 验证通过：appInForeground false→true 重触发成功",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": true,
        "enabled": true,
        "executionMode": "REPEAT"
      }
    }
  ],
  "termination": {
    "type": "allGoalsDone"
  },
  "pacingPreset": "STANDARD",
  "scanConfig": {
    "idleIntervalMs": 500,
    "activeIntervalMs": 200,
    "fallbackToImageMatch": false
  },
  "returnToApp": false
}