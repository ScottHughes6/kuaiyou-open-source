{
  "id": "reactive_test_toutiao_openai_article_flow_scroll_path",
  "name": "今日头条 OpenAI 文章综合流程测试 ScrollPath 版",
  "description": "首页进入搜索页，输入 OpenAI，执行搜索，等待结果后使用录制滑动路径滚动查找并点击包含 OpenAI 独家的结果进入详情，读取后通过 toast 展示。",
  "agentId": "agent_life",
  "goals": [
    {
      "id": "launch_toutiao",
      "name": "启动头条",
      "priority": 12,
      "trigger": {
        "type": "immediate"
      },
      "actions": [
        {
          "type": "launchApp",
          "packageName": "com.ss.android.article.news",
          "appName": "今日头条",
          "delayMs": 500,
          "timeoutMs": 8000
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    },
    {
      "id": "normalize_home",
      "name": "确认回到首页",
      "priority": 10,
      "trigger": {
        "type": "afterGoal",
        "goalId": "launch_toutiao"
      },
      "actions": [
        {
          "type": "conditionBranch",
          "condition": {
            "type": "elementVisible",
            "target": {
              "type": "desc",
              "desc": "听一听开关"
            }
          },
          "onTrue": [
            {
              "type": "delay",
              "durationMs": 400
            }
          ],
          "onFalse": [
            {
              "type": "systemAction",
              "systemType": "BACK",
              "delayMs": 300
            },
            {
              "type": "delay",
              "durationMs": 1200
            }
          ],
          "timeoutMs": 1200
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    },
    {
      "id": "open_search",
      "name": "点击首页搜索入口",
      "priority": 8,
      "trigger": {
        "type": "allOf",
        "triggers": [
          {
            "type": "afterGoal",
            "goalId": "normalize_home"
          },
          {
            "type": "elementVisible",
            "target": {
              "type": "id",
              "viewId": "com.ss.android.article.news:id/ki9"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "tap",
          "target": {
            "type": "id",
            "viewId": "com.ss.android.article.news:id/ki9"
          },
          "delayMs": 300,
          "timeoutMs": 2000
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    },
    {
      "id": "type_openai",
      "name": "输入 OpenAI",
      "priority": 6,
      "trigger": {
        "type": "allOf",
        "triggers": [
          {
            "type": "afterGoal",
            "goalId": "open_search"
          },
          {
            "type": "elementVisible",
            "target": {
              "type": "id",
              "viewId": "com.ss.android.article.news:id/cx"
            }
          },
          {
            "type": "elementVisible",
            "target": {
              "type": "id",
              "viewId": "com.ss.android.article.news:id/e0"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "typeText",
          "text": "OpenAI",
          "target": {
            "type": "id",
            "viewId": "com.ss.android.article.news:id/cx"
          },
          "clearFirst": true,
          "mode": "DEFAULT",
          "delayMs": 300,
          "timeoutMs": 2500
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    },
    {
      "id": "submit_search",
      "name": "点击搜索按钮",
      "priority": 5,
      "trigger": {
        "type": "allOf",
        "triggers": [
          {
            "type": "afterGoal",
            "goalId": "type_openai"
          },
          {
            "type": "elementVisible",
            "target": {
              "type": "id",
              "viewId": "com.ss.android.article.news:id/e0"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "tap",
          "target": {
            "type": "id",
            "viewId": "com.ss.android.article.news:id/e0"
          },
          "delayMs": 300,
          "timeoutMs": 2500
        },
        {
          "type": "notify",
          "message": "已点击搜索按钮，等待结果页",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    },
    {
      "id": "wait_results",
      "name": "等待搜索结果页",
      "priority": 4,
      "trigger": {
        "type": "afterGoal",
        "goalId": "submit_search"
      },
      "actions": [
        {
          "type": "waitFor",
          "condition": {
            "type": "elementVisible",
            "target": {
              "type": "text",
              "text": "OpenAI",
              "exact": false
            }
          },
          "timeoutMs": 6000
        },
        {
          "type": "notify",
          "message": "已进入搜索结果页",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    },
    {
      "id": "open_target_article",
      "name": "滚动定位并打开包含 OpenAI 独家的主题",
      "priority": 3,
      "trigger": {
        "type": "afterGoal",
        "goalId": "wait_results"
      },
      "actions": [
        {
          "type": "scrollTo",
          "target": {
            "type": "composite",
            "text": "独家",
            "textExact": false,
            "index": 0
          },
          "direction": "UP",
          "scrollPath": {
            "startXPct": 0.5,
            "startYPct": 0.76,
            "endXPct": 0.5,
            "endYPct": 0.42,
            "durationMs": 520
          },
          "maxScrolls": 5,
          "scrollDurationMs": 420,
          "settleDelayMs": 800,
          "scrollRegion": {
            "leftPct": 0.08,
            "topPct": 0.32,
            "rightPct": 0.92,
            "bottomPct": 0.88
          },
          "tapWhenFound": true,
          "delayMs": 1000,
          "timeoutMs": 4500
        },
        {
          "type": "notify",
          "message": "已滚动定位并点击目标文章",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    },
    {
      "id": "wait_article_detail",
      "name": "等待文章详情页",
      "priority": 2,
      "trigger": {
        "type": "afterGoal",
        "goalId": "open_target_article"
      },
      "actions": [
        {
          "type": "waitFor",
          "condition": {
            "type": "anyOf",
            "conditions": [
              {
                "type": "elementVisible",
                "target": {
                  "type": "text",
                  "text": "分享",
                  "exact": false
                }
              },
              {
                "type": "elementVisible",
                "target": {
                  "type": "text",
                  "text": "评论",
                  "exact": false
                }
              },
              {
                "type": "elementVisible",
                "target": {
                  "type": "text",
                  "text": "收藏",
                  "exact": false
                }
              }
            ]
          },
          "timeoutMs": 10000
        },
        {
          "type": "notify",
          "message": "已进入文章详情页",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    },
    {
      "id": "read_title",
      "name": "读取文章部分内容并显示",
      "priority": 1,
      "trigger": {
        "type": "allOf",
        "triggers": [
          {
            "type": "afterGoal",
            "goalId": "wait_article_detail"
          },
          {
            "type": "elementVisible",
            "target": {
              "type": "text",
              "text": "OpenAI",
              "exact": false
            }
          }
        ]
      },
      "actions": [
        {
          "type": "readText",
          "target": {
            "type": "text",
            "text": "OpenAI",
            "exact": false
          },
          "variableName": "article_title",
          "delayMs": 300,
          "timeoutMs": 2500
        },
        {
          "type": "notify",
          "message": "发现内容：{{article_title}}",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    }
  ],
  "termination": {
    "type": "allGoalsDone"
  },
  "pacingPreset": "STANDARD",
  "scanConfig": {
    "idleIntervalMs": 700,
    "activeIntervalMs": 300,
    "fallbackToImageMatch": false
  },
  "returnToApp": false
}
