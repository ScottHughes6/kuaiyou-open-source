{
  "id": "reactive_test_toutiao",
  "name": "今日头条测试",
  "description": "反应式引擎多步实机验证：打开今日头条 -> 等待首页加载 -> 点击热榜",
  "agentId": "agent_life",
  "goals": [
    {
      "id": "launch_toutiao",
      "name": "启动头条",
      "priority": 10,
      "trigger": { "type": "immediate" },
      "actions": [
        {
          "type": "launchApp",
          "packageName": "com.ss.android.article.news",
          "appName": "今日头条",
          "delayMs": 500,
          "timeoutMs": 8000
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    },
    {
      "id": "click_hot",
      "name": "点击热榜",
      "priority": 5,
      "trigger": {
        "type": "allOf",
        "triggers": [
          { "type": "afterGoal", "goalId": "launch_toutiao" },
          { "type": "elementVisible", "target": { "type": "desc", "desc": "热榜" } }
        ]
      },
      "actions": [
        {
          "type": "notify",
          "message": "发现热榜入口，准备点击",
          "speakVoice": true,
          "delayMs": 0
        },
        {
          "type": "tap",
          "target": { "type": "desc", "desc": "热榜" },
          "delayMs": 500
        },
        {
          "type": "notify",
          "message": "已成功点击热榜",
          "speakVoice": true,
          "delayMs": 500
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true
      }
    }
  ],
  "termination": { "type": "allGoalsDone" },
  "pacingPreset": "STANDARD",
  "scanConfig": {
    "idleIntervalMs": 800,
    "activeIntervalMs": 400,
    "fallbackToImageMatch": false
  },
  "returnToApp": false
}
