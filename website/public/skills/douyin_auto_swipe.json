{
  "id": "reactive_douyin_auto_swipe",
  "name": "抖音自动刷视频",
  "description": "打开抖音并自动每隔10秒上滑看下一个短视频",
  "agentId": "agent_life",
  "goals": [
    {
      "id": "launch_douyin",
      "name": "启动抖音",
      "priority": 10,
      "trigger": { "type": "immediate" },
      "actions": [
        {
          "type": "launchApp",
          "packageName": "com.ss.android.ugc.aweme",
          "appName": "抖音",
          "delayMs": 500,
          "timeoutMs": 8000
        },
        {
          "type": "notify",
          "message": "已启动抖音，准备开始自动刷视频",
          "speakVoice": true,
          "delayMs": 2000
        }
      ],
      "constraints": { "maxExecutions": 1, "cooldownMs": 0, "continueOnFailure": false, "enabled": true }
    },
    {
      "id": "auto_swipe",
      "name": "循环上滑视频",
      "priority": 5,
      "trigger": {
        "type": "afterGoal",
        "goalId": "launch_douyin"
      },
      "actions": [
        {
          "type": "swipe",
          "startXPct": 0.5,
          "startYPct": 0.8,
          "endXPct": 0.5,
          "endYPct": 0.2,
          "durationMs": 300,
          "delayMs": 0
        },
        {
          "type": "notify",
          "message": "正在观看当前视频...",
          "showText": true,
          "speakVoice": false,
          "delayMs": 0
        }
      ],
      "constraints": { 
        "maxExecutions": 0, 
        "cooldownMs": 10000, 
        "continueOnFailure": true, 
        "enabled": true 
      }
    }
  ],
  "termination": { "type": "allGoalsDone" },
  "pacingPreset": "STANDARD",
  "scanConfig": {
    "idleIntervalMs": 1000,
    "activeIntervalMs": 500,
    "fallbackToImageMatch": false
  },
  "returnToApp": false
}
