{
  "id": "reactive_test_repeat_mode_foreground_v2",
  "name": "REPEAT 模式验证 v2 - 前台检测（无自动启动）",
  "description": "使用前请手动打开今日头条，再启动本技能。验证三个核心行为：①进入前台立即触发；②保持前台不重复；③切走再切回重新触发。技能运行 300 秒后自动结束。",
  "agentId": "agent_life",
  "goals": [
    {
      "id": "detect_foreground_repeat",
      "name": "检测今日头条前台（重复步骤）",
      "priority": 8,
      "trigger": {
        "type": "appInForeground",
        "packageName": "com.ss.android.article.news"
      },
      "actions": [
        {
          "type": "notify",
          "message": "✅ REPEAT 触发：今日头条进入前台",
          "showText": true,
          "speakVoice": false
        },
        {
          "type": "delay",
          "durationMs": 300
        }
      ],
      "constraints": {
        "maxExecutions": 0,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "REPEAT"
      }
    }
  ],
  "termination": {
    "type": "timeout",
    "maxDurationMs": 300000
  },
  "pacingPreset": "STANDARD",
  "scanConfig": {
    "idleIntervalMs": 500,
    "activeIntervalMs": 200,
    "fallbackToImageMatch": false
  },
  "returnToApp": false
}
