{
  "id": "reactive_test_repeat_mode_foreground",
  "name": "REPEAT 模式验证 - 今日头条前台检测",
  "description": "验证 REPEAT 执行模式的三个核心行为：①当前可见立即执行；②保持可见不重复；③消失再出现后重新执行。步骤：先启动今日头条，然后通过 appInForeground 触发器+REPEAT 模式检测前台切换，每次进入前台都通知一次，保持前台期间不重复触发。",
  "agentId": "agent_life",
  "goals": [
    {
      "id": "launch_toutiao",
      "name": "启动今日头条",
      "priority": 10,
      "trigger": {
        "type": "immediate"
      },
      "actions": [
        {
          "type": "launchApp",
          "packageName": "com.ss.android.article.news",
          "appName": "今日头条",
          "delayMs": 500,
          "timeoutMs": 8000
        },
        {
          "type": "notify",
          "message": "技能已启动，等待今日头条进入前台…",
          "showText": true,
          "speakVoice": false
        }
      ],
      "constraints": {
        "maxExecutions": 1,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "SINGLE"
      }
    },
    {
      "id": "detect_foreground_repeat",
      "name": "检测前台（重复步骤）",
      "priority": 8,
      "trigger": {
        "type": "appInForeground",
        "packageName": "com.ss.android.article.news"
      },
      "actions": [
        {
          "type": "notify",
          "message": "✅ REPEAT 触发：今日头条进入前台",
          "showText": true,
          "speakVoice": false
        },
        {
          "type": "delay",
          "durationMs": 300
        }
      ],
      "constraints": {
        "maxExecutions": 0,
        "cooldownMs": 0,
        "continueOnFailure": false,
        "enabled": true,
        "executionMode": "REPEAT"
      }
    }
  ],
  "termination": {
    "type": "timeout",
    "maxDurationMs": 60000
  },
  "pacingPreset": "STANDARD",
  "scanConfig": {
    "idleIntervalMs": 500,
    "activeIntervalMs": 200,
    "fallbackToImageMatch": false
  },
  "returnToApp": false
}
