{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kuaiyou.app/schemas/reactive-skill/v2.json",
  "title": "ReactiveSkill",
  "description": "快游大师 反应式技能 Schema v2（端上可执行动作契约）。本地 Agent 通过设备 MCP 拉取本 Schema，编排/升级技能后 POST 部署到 App。顶层为 ReactiveSkill；执行由引擎按屏幕状态驱动 goals，interrupts 为全局前置拦截。动作必须收敛到端上可执行列表（tap/typeText/swipe 等），不含执行期外联 LLM。MCP 导入的技能一律视为本地手工技能：不暴露内部助理归属字段。反序列化使用 kotlinx.serialization：判别字段 \"type\"=@SerialName；ignoreUnknownKeys=true。",
  "type": "object",
  "required": ["id", "name", "description", "goals"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1, "description": "技能唯一 ID" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "icon": { "type": "string", "default": "auto_awesome" },
    "executionMode": { "type": "string", "enum": ["REACTIVE"], "default": "REACTIVE", "description": "旧值 SEQUENTIAL 兼容解析为 REACTIVE" },
    "goals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/SkillGoal" }
    },
    "launchApp": {
      "description": "全局启动应用配置，等价于一个 launchApp GoalAction",
      "anyOf": [{ "$ref": "#/definitions/Action_launchApp" }, { "type": "null" }]
    },
    "pacingPreset": { "type": "string", "enum": ["FAST", "STANDARD", "CAREFUL"], "default": "STANDARD" },
    "popupRules": {
      "type": "array",
      "description": "【已废弃】旧版弹窗拦截规则。解码时自动迁移到 interrupts（trigger→when）。新技能请直接用 interrupts。",
      "items": { "$ref": "#/definitions/PopupRule" },
      "default": []
    },
    "interrupts": {
      "type": "array",
      "description": "Schema v2 新增：与 goals 平级的全局中断规则，用于前置拦截广告/权限/更新弹窗。每轮扫描优先检查，命中即执行 dismiss。",
      "items": { "$ref": "#/definitions/Interrupt" },
      "default": []
    },
    "termination": {
      "description": "终止条件，默认所有目标完成后终止",
      "$ref": "#/definitions/TerminationCondition"
    },
    "scanConfig": { "$ref": "#/definitions/ScanConfig" },
    "humanization": { "type": "object", "description": "拟人化执行配置，默认 OFF" },
    "returnToApp": { "type": "boolean", "default": false },
    "debugStatus": { "type": "string", "enum": ["INCOMPLETE", "PENDING_TEST", "TESTED"], "default": "INCOMPLETE" },
    "createdAt": { "type": "integer" },
    "updatedAt": { "type": "integer" }
  },

  "definitions": {

    "SkillGoal": {
      "type": "object",
      "required": ["id", "name", "trigger"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1, "description": "步骤唯一 ID，供 afterGoal / runStep 引用" },
        "name": { "type": "string", "minLength": 1 },
        "priority": { "type": "integer", "default": 0, "description": "越大越优先" },
        "trigger": { "$ref": "#/definitions/GoalTrigger" },
        "action": {
          "description": "触发后执行的单个动作（一步一动作）。仅 immediate trigger 允许省略。旧数据的 actions 数组会在解码前归一化。",
          "anyOf": [{ "$ref": "#/definitions/GoalAction" }, { "type": "null" }]
        },
        "completion": { "$ref": "#/definitions/GoalCompletion" },
        "completionPolicy": {
          "anyOf": [
            { "type": "string", "enum": ["WARNING_ONLY", "STRICT_FAIL", "RETRY_THEN_FAIL"] },
            { "type": "null" }
          ],
          "default": null
        },
        "completionRetryCount": { "type": "integer", "default": 3 },
        "constraints": { "$ref": "#/definitions/GoalConstraints" },
        "note": { "type": "string", "default": "" }
      }
    },

    "GoalConstraints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "maxExecutions": { "type": "integer", "default": 0, "description": "0=不限" },
        "cooldownMs": { "type": "integer", "default": 10000 },
        "continueOnFailure": { "type": "boolean", "default": false },
        "enabled": { "type": "boolean", "default": true },
        "optional": { "type": "boolean", "default": false },
        "fallbackPolicy": { "type": "string", "enum": ["AUTO_ONLY", "ALLOW_PROMPT", "STRICT"], "default": "AUTO_ONLY" },
        "executionMode": { "type": "string", "enum": ["SINGLE", "REPEAT"], "default": "REPEAT" },
        "loopFailurePolicy": { "type": "string", "enum": ["SKIP_ROUND", "ABORT", "RETRY_AFTER_COOLDOWN"], "default": "SKIP_ROUND" },
        "recognitionTimeoutMs": { "type": "integer", "default": 20000 },
        "maxRecognitionAttempts": { "type": "integer", "default": 3 }
      }
    },

    "ScanConfig": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "idleIntervalMs": { "type": "integer", "default": 500 },
        "activeIntervalMs": { "type": "integer", "default": 200 },
        "fallbackToImageMatch": { "type": "boolean", "default": true },
        "enableImageCondition": { "type": "boolean", "default": false },
        "enableCompositeFallbackPermission": { "type": "boolean", "default": false },
        "enableUnifiedResolver": { "type": "boolean", "default": false },
        "enableStrictCompletion": { "type": "boolean", "default": false }
      }
    },

    "PopupRule": {
      "type": "object",
      "description": "旧模型，保留兼容。",
      "required": ["name", "trigger", "dismiss"],
      "properties": {
        "name": { "type": "string" },
        "trigger": { "$ref": "#/definitions/TargetSelector" },
        "dismiss": { "$ref": "#/definitions/TargetSelector" },
        "priority": { "type": "integer", "default": 0 }
      }
    },

    "Interrupt": {
      "type": "object",
      "description": "Schema v2 全局中断规则。",
      "required": ["name", "when", "dismiss"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "when": {
          "description": "命中条件：该目标出现即认定干扰弹窗出现。",
          "$ref": "#/definitions/TargetSelector"
        },
        "dismiss": {
          "description": "命中后的处置目标（通常是关闭/跳过/我知道了按钮）。",
          "$ref": "#/definitions/TargetSelector"
        },
        "priority": { "type": "integer", "default": 0 },
        "enabled": { "type": "boolean", "default": true }
      }
    },

    "TerminationCondition": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "properties": { "type": { "const": "allGoalsDone" } },
          "required": ["type"]
        },
        {
          "properties": {
            "type": { "const": "anyGoalDone" },
            "goalIds": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["type", "goalIds"]
        },
        {
          "properties": { "type": { "const": "manual" } },
          "required": ["type"]
        },
        {
          "properties": {
            "type": { "const": "timeout" },
            "maxDurationMs": { "type": "integer" }
          },
          "required": ["type", "maxDurationMs"]
        },
        {
          "properties": {
            "type": { "const": "idleTimeout" },
            "maxIdleMs": { "type": "integer" }
          },
          "required": ["type", "maxIdleMs"]
        }
      ]
    },

    "GoalTrigger": {
      "type": "object",
      "description": "何时执行一个目标。判别字段 type。",
      "required": ["type"],
      "oneOf": [
        { "properties": { "type": { "const": "elementVisible" }, "target": { "$ref": "#/definitions/TargetSelector" } }, "required": ["type", "target"] },
        { "properties": { "type": { "const": "elementGone" }, "target": { "$ref": "#/definitions/TargetSelector" } }, "required": ["type", "target"] },
        { "properties": { "type": { "const": "appInForeground" }, "packageName": { "type": "string" } }, "required": ["type", "packageName"] },
        { "properties": { "type": { "const": "appNotInForeground" }, "packageName": { "type": "string" } }, "required": ["type", "packageName"] },
        { "properties": { "type": { "const": "afterGoal" }, "goalId": { "type": "string" } }, "required": ["type", "goalId"] },
        { "properties": { "type": { "const": "delayedAfterGoal" }, "goalId": { "type": "string" }, "delayMs": { "type": "integer" } }, "required": ["type", "goalId", "delayMs"] },
        { "properties": { "type": { "const": "immediate" } }, "required": ["type"] },
        { "properties": { "type": { "const": "anyOf" }, "triggers": { "type": "array", "items": { "$ref": "#/definitions/GoalTrigger" } } }, "required": ["type", "triggers"] },
        { "properties": { "type": { "const": "allOf" }, "triggers": { "type": "array", "items": { "$ref": "#/definitions/GoalTrigger" } } }, "required": ["type", "triggers"] }
      ]
    },

    "GoalCompletion": {
      "type": "object",
      "description": "如何判定目标完成。默认 onActionsComplete。",
      "required": ["type"],
      "oneOf": [
        { "properties": { "type": { "const": "onActionsComplete" } }, "required": ["type"] },
        { "properties": { "type": { "const": "elementAppears" }, "target": { "$ref": "#/definitions/TargetSelector" } }, "required": ["type", "target"] },
        { "properties": { "type": { "const": "elementGone" }, "target": { "$ref": "#/definitions/TargetSelector" } }, "required": ["type", "target"] }
      ]
    },

    "GoalCondition": {
      "type": "object",
      "description": "Goal 内局部条件（用于 waitFor / assertion）。判别字段 type。",
      "required": ["type"],
      "oneOf": [
        { "properties": { "type": { "const": "elementVisible" }, "target": { "$ref": "#/definitions/TargetSelector" } }, "required": ["type", "target"] },
        { "properties": { "type": { "const": "elementGone" }, "target": { "$ref": "#/definitions/TargetSelector" } }, "required": ["type", "target"] },
        { "properties": { "type": { "const": "appInForeground" }, "packageName": { "type": "string" } }, "required": ["type", "packageName"] },
        { "properties": { "type": { "const": "appNotInForeground" }, "packageName": { "type": "string" } }, "required": ["type", "packageName"] },
        { "properties": { "type": { "const": "timeElapsed" }, "durationMs": { "type": "integer" } }, "required": ["type", "durationMs"] },
        { "properties": { "type": { "const": "anyOf" }, "conditions": { "type": "array", "items": { "$ref": "#/definitions/GoalCondition" } } }, "required": ["type", "conditions"] },
        { "properties": { "type": { "const": "allOf" }, "conditions": { "type": "array", "items": { "$ref": "#/definitions/GoalCondition" } } }, "required": ["type", "conditions"] }
      ]
    },

    "TargetSelector": {
      "type": "object",
      "description": "如何找到一个 UI 元素。判别字段 type。",
      "required": ["type"],
      "oneOf": [
        {
          "title": "ByText",
          "properties": {
            "type": { "const": "text" },
            "text": { "type": "string" },
            "exact": { "type": "boolean", "default": false },
            "matchMode": { "type": "string", "enum": ["EXACT", "CONTAINS", "REGEX", "STARTS_WITH", "ENDS_WITH"], "description": "优先级高于 exact；缺省时按 exact 推断 EXACT/CONTAINS" }
          },
          "required": ["type", "text"]
        },
        {
          "title": "ByDescription",
          "properties": { "type": { "const": "desc" }, "desc": { "type": "string" } },
          "required": ["type", "desc"]
        },
        {
          "title": "ById",
          "properties": { "type": { "const": "id" }, "viewId": { "type": "string" } },
          "required": ["type", "viewId"]
        },
        {
          "title": "ByPosition",
          "properties": {
            "type": { "const": "pos" },
            "xPct": { "type": "number", "minimum": 0, "maximum": 1 },
            "yPct": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "required": ["type", "xPct", "yPct"]
        },
        {
          "title": "Semantic",
          "description": "Schema v2 新增：视觉语义目标。用自然语言描述要找什么，打破写死 text/viewId 的局限。解析降级链：hintText/hintDesc 无障碍快速路径 → 视觉 Agent（依据 description + 屏幕上下文）→ TARGET_NOT_FOUND。",
          "properties": {
            "type": { "const": "semantic" },
            "description": { "type": "string", "minLength": 1, "description": "例：右上角的关闭按钮 / 底部蓝色的立即购买按钮" },
            "hintText": { "type": ["string", "null"], "default": null, "description": "可选加速提示：按文本先做无障碍查找" },
            "hintDesc": { "type": ["string", "null"], "default": null, "description": "可选加速提示：按 contentDescription 查找" }
          },
          "required": ["type", "description"]
        },
        {
          "title": "ByImage",
          "properties": {
            "type": { "const": "image" },
            "imagePath": { "type": "string" },
            "threshold": { "type": "number", "default": 0.8, "minimum": 0, "maximum": 1 },
            "tapOffsetXPct": { "type": "number", "default": 0 },
            "tapOffsetYPct": { "type": "number", "default": 0 },
            "searchRegion": { "anyOf": [{ "$ref": "#/definitions/SearchRegion" }, { "type": "null" }] },
            "targetPackageName": { "type": ["string", "null"] }
          },
          "required": ["type", "imagePath"]
        },
        {
          "title": "Composite",
          "properties": {
            "type": { "const": "composite" },
            "text": { "type": ["string", "null"] },
            "description": { "type": ["string", "null"] },
            "viewId": { "type": ["string", "null"] },
            "className": { "type": ["string", "null"] },
            "index": { "type": "integer", "default": 0 },
            "previewImagePath": { "type": ["string", "null"] },
            "targetPackageName": { "type": ["string", "null"] }
          },
          "required": ["type"]
        }
      ]
    },

    "SearchRegion": {
      "type": "object",
      "required": ["leftPct", "topPct", "rightPct", "bottomPct"],
      "properties": {
        "leftPct": { "type": "number", "minimum": 0, "maximum": 1 },
        "topPct": { "type": "number", "minimum": 0, "maximum": 1 },
        "rightPct": { "type": "number", "minimum": 0, "maximum": 1 },
        "bottomPct": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "GoalAction": {
      "type": "object",
      "description": "反应式引擎动作。判别字段 type。所有动作含公共可选字段 delayMs / timeoutMs / note。",
      "required": ["type"],
      "oneOf": [
        { "$ref": "#/definitions/Action_tap" },
        { "$ref": "#/definitions/Action_longTap" },
        { "$ref": "#/definitions/Action_typeText" },
        { "$ref": "#/definitions/Action_swipe" },
        { "$ref": "#/definitions/Action_scrollTo" },
        { "$ref": "#/definitions/Action_launchApp" },
        { "$ref": "#/definitions/Action_systemAction" },
        { "$ref": "#/definitions/Action_storeValue" },
        { "$ref": "#/definitions/Action_notify" },
        { "$ref": "#/definitions/Action_delay" },
        { "$ref": "#/definitions/Action_waitFor" },
        { "$ref": "#/definitions/Action_assertion" },
        { "$ref": "#/definitions/Action_conditionBranch" },
        { "$ref": "#/definitions/Action_loop" },
        { "$ref": "#/definitions/Action_runStep" },
        { "$ref": "#/definitions/Action_captureScreenshot" }
      ]
    },

    "Action_tap": {
      "type": "object",
      "properties": {
        "type": { "const": "tap" },
        "target": { "$ref": "#/definitions/TargetSelector" },
        "fallbacks": { "type": "array", "items": { "$ref": "#/definitions/TargetSelector" }, "default": [] },
        "timeoutMs": { "type": "integer", "default": 2000 },
        "delayMs": { "type": "integer", "default": 300 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "target"]
    },

    "Action_longTap": {
      "type": "object",
      "properties": {
        "type": { "const": "longTap" },
        "target": { "$ref": "#/definitions/TargetSelector" },
        "pressDurationMs": { "type": "integer", "default": 500 },
        "fingerCount": { "type": "integer", "default": 1 },
        "timeoutMs": { "type": "integer", "default": 2000 },
        "delayMs": { "type": "integer", "default": 300 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "target"]
    },

    "Action_typeText": {
      "type": "object",
      "properties": {
        "type": { "const": "typeText" },
        "text": { "type": "string" },
        "target": { "$ref": "#/definitions/TargetSelector" },
        "clearFirst": { "type": "boolean", "default": false },
        "mode": { "type": "string", "enum": ["DEFAULT", "PASTE", "WECHAT_SPECIAL"], "default": "DEFAULT" },
        "timeoutMs": { "type": "integer", "default": 2000 },
        "delayMs": { "type": "integer", "default": 300 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "text", "target"]
    },

    "Action_swipe": {
      "type": "object",
      "description": "滑动。坐标二选一：默认全屏百分比；Schema v2 起可选 target 锚点控件，以命中控件为原点做相对滑动，target 解析失败回退全屏百分比。",
      "properties": {
        "type": { "const": "swipe" },
        "startXPct": { "type": "number", "minimum": 0, "maximum": 1 },
        "startYPct": { "type": "number", "minimum": 0, "maximum": 1 },
        "endXPct": { "type": "number", "minimum": 0, "maximum": 1 },
        "endYPct": { "type": "number", "minimum": 0, "maximum": 1 },
        "durationMs": { "type": "integer", "default": 300 },
        "fingerCount": { "type": "integer", "default": 1 },
        "target": {
          "description": "Schema v2 新增：相对滑动锚点控件；null 时使用全屏百分比。",
          "anyOf": [{ "$ref": "#/definitions/TargetSelector" }, { "type": "null" }],
          "default": null
        },
        "delayMs": { "type": "integer", "default": 200 },
        "timeoutMs": { "type": "integer", "default": 2000 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "startXPct", "startYPct", "endXPct", "endYPct"]
    },

    "Action_scrollTo": {
      "type": "object",
      "properties": {
        "type": { "const": "scrollTo" },
        "target": { "$ref": "#/definitions/TargetSelector" },
        "direction": { "type": "string", "enum": ["UP", "DOWN", "LEFT", "RIGHT"], "default": "UP" },
        "maxScrolls": { "type": "integer", "default": 5 },
        "scrollDurationMs": { "type": "integer", "default": 350 },
        "settleDelayMs": { "type": "integer", "default": 500 },
        "tapWhenFound": { "type": "boolean", "default": false },
        "timeoutMs": { "type": "integer", "default": 1200 },
        "delayMs": { "type": "integer", "default": 200 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "target"]
    },

    "Action_launchApp": {
      "type": "object",
      "properties": {
        "type": { "const": "launchApp" },
        "packageName": { "type": "string" },
        "appName": { "type": ["string", "null"] },
        "expectedPackageName": { "type": ["string", "null"] },
        "activityName": { "type": ["string", "null"] },
        "chooserOptionKeywords": { "type": "array", "items": { "type": "string" }, "default": [] },
        "chooserConfirmKeywords": { "type": "array", "items": { "type": "string" }, "default": [] },
        "cloneTarget": { "anyOf": [{ "$ref": "#/definitions/TargetSelector" }, { "type": "null" }] },
        "manualSelectionEnabled": { "type": "boolean", "default": false },
        "manualSelectionWaitMs": { "type": "integer", "default": 8000 },
        "intentAction": { "type": ["string", "null"] },
        "intentType": { "type": ["string", "null"] },
        "intentExtraText": { "type": ["string", "null"] },
        "forceFreshStart": { "type": "boolean", "default": false },
        "timeoutMs": { "type": "integer", "default": 8000 },
        "delayMs": { "type": "integer", "default": 1000 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "packageName"]
    },

    "Action_systemAction": {
      "type": "object",
      "properties": {
        "type": { "const": "systemAction" },
        "systemType": { "type": "string", "enum": ["BACK", "HOME", "RECENTS", "NOTIFICATIONS", "QUICK_SETTINGS"] },
        "timeoutMs": { "type": "integer", "default": 1000 },
        "delayMs": { "type": "integer", "default": 200 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "systemType"]
    },

    "Action_storeValue": {
      "type": "object",
      "properties": {
        "type": { "const": "storeValue" },
        "source": {
          "type": "object",
          "required": ["type"],
          "oneOf": [
            { "properties": { "type": { "const": "screen" }, "target": { "$ref": "#/definitions/TargetSelector" } }, "required": ["type", "target"] },
            { "properties": { "type": { "const": "template" }, "text": { "type": "string" } }, "required": ["type", "text"] }
          ]
        },
        "variableName": { "type": "string", "default": "text" },
        "copyToClipboard": { "type": "boolean", "default": false },
        "timeoutMs": { "type": "integer", "default": 2000 },
        "delayMs": { "type": "integer", "default": 300 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "source"]
    },

    "Action_notify": {
      "type": "object",
      "properties": {
        "type": { "const": "notify" },
        "message": { "type": "string" },
        "showText": { "type": "boolean", "default": false },
        "speakVoice": { "type": "boolean", "default": true },
        "timeoutMs": { "type": "integer", "default": 10000 },
        "delayMs": { "type": "integer", "default": 0 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "message"]
    },

    "Action_delay": {
      "type": "object",
      "properties": {
        "type": { "const": "delay" },
        "durationMs": { "type": "integer" },
        "delayMs": { "type": "integer", "default": 0 },
        "timeoutMs": { "type": "integer", "default": 0 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "durationMs"]
    },

    "Action_waitFor": {
      "type": "object",
      "properties": {
        "type": { "const": "waitFor" },
        "condition": { "$ref": "#/definitions/GoalCondition" },
        "timeoutMs": { "type": "integer", "default": 5000 },
        "delayMs": { "type": "integer", "default": 0 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "condition"]
    },

    "Action_assertion": {
      "type": "object",
      "properties": {
        "type": { "const": "assertion" },
        "condition": { "$ref": "#/definitions/GoalCondition" },
        "failureMessage": { "type": "string", "default": "" },
        "timeoutMs": { "type": "integer", "default": 1500 },
        "delayMs": { "type": "integer", "default": 0 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "condition"]
    },

    "Action_conditionBranch": {
      "type": "object",
      "properties": {
        "type": { "const": "conditionBranch" },
        "condition": { "$ref": "#/definitions/GoalCondition" },
        "onTrue": { "type": "array", "items": { "$ref": "#/definitions/GoalAction" } },
        "onFalse": { "type": "array", "items": { "$ref": "#/definitions/GoalAction" } },
        "timeoutMs": { "type": "integer", "default": 5000 },
        "delayMs": { "type": "integer", "default": 0 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "condition", "onTrue", "onFalse"]
    },

    "Action_loop": {
      "type": "object",
      "properties": {
        "type": { "const": "loop" },
        "actions": { "type": "array", "items": { "$ref": "#/definitions/GoalAction" } },
        "iterations": { "type": "integer", "default": -1, "description": "正数=次数；-1=无限；0=跳过" },
        "intervalMs": { "type": "integer", "default": 1000 },
        "stopWhenMissing": { "type": "boolean", "default": false },
        "timeoutMs": { "type": "integer", "default": 0 },
        "delayMs": { "type": "integer", "default": 0 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "actions"]
    },

    "Action_runStep": {
      "type": "object",
      "description": "引用技能内已存在的步骤（单一事实来源），仅作为 conditionBranch/loop 子动作使用。",
      "properties": {
        "type": { "const": "runStep" },
        "goalId": { "type": "string" },
        "timeoutMs": { "type": "integer", "default": 0 },
        "delayMs": { "type": "integer", "default": 0 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "goalId"]
    },

    "Action_captureScreenshot": {
      "type": "object",
      "properties": {
        "type": { "const": "captureScreenshot" },
        "savePath": { "type": "string" },
        "imageFormat": { "type": "string", "enum": ["PNG", "JPEG"], "default": "JPEG" },
        "quality": { "type": "integer", "default": 80, "minimum": 0, "maximum": 100 },
        "timeoutMs": { "type": "integer", "default": 5000 },
        "delayMs": { "type": "integer", "default": 300 },
        "note": { "type": "string", "default": "" }
      },
      "required": ["type", "savePath"]
    }
  }
}
